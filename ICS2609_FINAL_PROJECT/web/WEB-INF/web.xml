<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <listener>
        <description>ServletContextListener</description>
        <listener-class>listeners.AppContextListener</listener-class>
    </listener>

    <context-param>
        <param-name>Derby_Driver</param-name>
        <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
    </context-param>
    <context-param>
        <param-name>Derby_URL</param-name>
        <param-value>jdbc:derby://localhost:1527/authDB;create=true</param-value>
    </context-param>
    <context-param>
        <param-name>Derby_User</param-name>
        <param-value>app</param-value>
    </context-param>
    <context-param>
        <param-name>Derby_Pass</param-name>
        <param-value>app</param-value>
    </context-param>

    <context-param>
        <param-name>MySQL_Driver</param-name>
        <param-value>com.mysql.cj.jdbc.Driver</param-value>
    </context-param>
    <context-param>
        <param-name>MySQL_URL</param-name>
        <param-value>jdbc:mysql://localhost:3306/course_management_db</param-value>
    </context-param>
    <context-param>
        <param-name>MySQL_User</param-name>
        <param-value>root</param-value>
    </context-param>
    <context-param>
        <param-name>MySQL_Pass</param-name>
        <param-value>your_mysql_password</param-value>
    </context-param>

    <context-param>
        <param-name>Postgres_Driver</param-name>
        <param-value>org.postgresql.Driver</param-value>
    </context-param>
    <context-param>
        <param-name>Postgres_URL</param-name>
        <param-value>jdbc:postgresql://localhost:5432/course_logs</param-value>
    </context-param>
    <context-param>
        <param-name>Postgres_User</param-name>
        <param-value>postgres</param-value>
    </context-param>
    <context-param>
        <param-name>Postgres_Pass</param-name>
        <param-value>your_password_here</param-value>
    </context-param>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
