<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>ICS2609 Course Management System</display-name>



    <!-- Google reCAPTCHA v2 Keys (FR-AUTH-008) -->
    <context-param>
        <param-name>recaptchaSiteKey</param-name>
        <param-value>6Le2DposAAAAAObHCVLnSeZFyad7TAcx9PN-B9Q_</param-value>
    </context-param>
    <context-param>
        <param-name>recaptchaSecretKey</param-name>
        <param-value>6Le2DposAAAAAKQ5rnDQRqtN_nyO0fxzHlPaYVZB</param-value>
    </context-param>

    <!-- PDF Report Header and Footer (FR-PDF-006) -->
    <context-param>
        <param-name>pdfHeader</param-name>
        <param-value>Active Learning, Inc. — Course Management System</param-value>
    </context-param>
    <context-param>
        <param-name>pdfFooter</param-name>
        <param-value>Generated by Active Learning, Inc. System | ICS2609 Final Project</param-value>
    </context-param>

    <!-- Application Name (used in reports and UI) -->
    <context-param>
        <param-name>appName</param-name>
        <param-value>Active Learning, Inc. Course Management System</param-value>
    </context-param>

    <!-- SysAdmin dashboard auto-refresh interval (seconds) -->
    <context-param>
        <param-name>sysAdminRefreshInterval</param-name>
        <param-value>30</param-value>
    </context-param>



    <!-- Apache Derby — authDB (user authentication) -->
    <context-param>
        <param-name>Derby_Driver</param-name>
        <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
    </context-param>
    <context-param>
        <param-name>Derby_URL</param-name>
        <param-value>jdbc:derby://localhost:1527/LoginDB</param-value>
    </context-param>
    <context-param>
        <param-name>Derby_User</param-name>
        <param-value>app</param-value>
    </context-param>
    <context-param>
        <param-name>Derby_Pass</param-name>
        <param-value>app</param-value>
    </context-param>

    <!-- MySQL — course_management_db (courses, modules, grades) -->
    <context-param>
        <param-name>MySQL_Driver</param-name>
        <param-value>com.mysql.cj.jdbc.Driver</param-value>
    </context-param>
    <context-param>
        <param-name>MySQL_URL</param-name>
        <param-value>jdbc:mysql://localhost:3306/course_management_db</param-value>
    </context-param>
    <context-param>
        <param-name>MySQL_User</param-name>
        <param-value>root</param-value>
    </context-param>
    <context-param>
        <param-name>MySQL_Pass</param-name>
        <param-value>app</param-value>
    </context-param>

    <!-- PostgreSQL — course_logs (audit/activity logs) -->
    <context-param>
        <param-name>Postgres_Driver</param-name>
        <param-value>org.postgresql.Driver</param-value>
    </context-param>
    <context-param>
        <param-name>Postgres_URL</param-name>
        <param-value>jdbc:postgresql://localhost:5432/postgres</param-value>
    </context-param>
    <context-param>
        <param-name>Postgres_User</param-name>
        <param-value>postgres</param-value>
    </context-param>
    <context-param>
        <param-name>Postgres_Pass</param-name>
        <param-value>app</param-value>
    </context-param>


    <session-config>
        <!-- Timeout in minutes: 5 minutes = 300 seconds -->
        <session-timeout>5</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    

    <servlet>
        <servlet-name>CaptchaServlet</servlet-name>
        <servlet-class>controller.CaptchaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CaptchaServlet</servlet-name>
        <url-pattern>/CaptchaServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>controller.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>



    <!-- AuthFilter: checks authentication and session timeout -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filters.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/guest/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/ReportServlet</url-pattern>
    </filter-mapping>

    <!-- RoleFilter: checks Admin role for admin-only resources (runs AFTER AuthFilter) -->
    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>filters.RoleFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>



    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>



    <error-page>
        <error-code>403</error-code>
        <location>/errors/unauthorized.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/errors/error_404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/errors/error_500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/errors/error_500.jsp</location>
    </error-page>

</web-app>
