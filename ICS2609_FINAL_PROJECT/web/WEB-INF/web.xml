<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>ICS2609 Course Management System</display-name>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 1: Context Parameters (Deployment Descriptor Configuration) -->
    <!-- Sensitive values are stored here per SRS NFR-SEC-003 / FR-DBMS-006 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Google reCAPTCHA v2 Keys (FR-AUTH-008) -->
    <context-param>
        <param-name>recaptchaSiteKey</param-name>
        <param-value>6Le2DposAAAAAObHCVLnSeZFyad7TAcx9PN-B9Q_</param-value>
    </context-param>
    <context-param>
        <param-name>recaptchaSecretKey</param-name>
        <param-value>6Le2DposAAAAAKQ5rnDQRqtN_nyO0fxzHlPaYVZB</param-value>
    </context-param>

    <!-- PDF Report Header and Footer (FR-PDF-006) -->
    <context-param>
        <param-name>pdfHeader</param-name>
        <param-value>Active Learning, Inc. — Course Management System</param-value>
    </context-param>
    <context-param>
        <param-name>pdfFooter</param-name>
        <param-value>Generated by Active Learning, Inc. System | ICS2609 Final Project</param-value>
    </context-param>

    <!-- Application Name (used in reports and UI) -->
    <context-param>
        <param-name>appName</param-name>
        <param-value>Active Learning, Inc. Course Management System</param-value>
    </context-param>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 2: Session Configuration                                   -->
    <!-- 5-minute session timeout (FR-AUTH-006, SessionUtil constant)       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <session-config>
        <!-- Timeout in minutes: 5 minutes = 300 seconds -->
        <session-timeout>5</session-timeout>
        <cookie-config>
            <!-- HttpOnly: prevents JavaScript from reading the session cookie -->
            <http-only>true</http-only>
            <!-- Secure: set to true when deployed over HTTPS in production -->
            <!-- <secure>true</secure> -->
            <same-site>Strict</same-site>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 3: Servlet Declarations                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <servlet>
        <servlet-name>CaptchaServlet</servlet-name>
        <servlet-class>controller.CaptchaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CaptchaServlet</servlet-name>
        <url-pattern>/CaptchaServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>controller.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 4: Filter Declarations                                     -->
    <!-- Filters are applied in DECLARATION ORDER for the same URL pattern  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- AuthFilter: checks authentication and session timeout -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filters.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/guest/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/ReportServlet</url-pattern>
    </filter-mapping>

    <!-- RoleFilter: checks Admin role for admin-only resources (runs AFTER AuthFilter) -->
    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>filters.RoleFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/ReportServlet</url-pattern>
    </filter-mapping>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 5: Welcome File                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 6: Custom Error Pages (NFR-USE-003, NFR-ERR-003)          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <error-page>
        <error-code>403</error-code>
        <location>/unauthorized.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error_404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error_500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error_500.jsp</location>
    </error-page>

</web-app>
